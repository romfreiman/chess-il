{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "paths": {
      "@shared/*": ["./packages/shared/*"]
    }
  },
  "include": ["src/**/*", "packages/**/*", "netlify/**/*"]
}
